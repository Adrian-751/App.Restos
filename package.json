{
  "name": "app-restos",
  "version": "1.0.0",
  "description": "Sistema de gestión para canchas de fútbol y restaurantes",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3"
  },
  "scripts": {
    "test": "npm run test:server && npm run test:client",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client",
    "test:e2e": "npx playwright test e2e/",
    "test:e2e:full": "npx playwright test e2e/full-app.spec.mjs",
    "test:e2e:headed": "npx playwright test e2e/ --headed",
    "test:e2e:debug": "npx playwright test e2e/ --debug",
    "test:all": "npm run test && npm run test:e2e"
  }
}
